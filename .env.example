# ~/quant/.env 가 있으면 자동으로 함께 읽는다 (이 파일의 값이 우선, 없으면 무시).
# 인식하는 별칭: TELEGRAM_BOT_TOKEN→TG_BOT_TOKEN, TELEGRAM_ALLOWED_USER_ID→TG_CHAT_ID
# 프라이빗키는 이 파일이 아니라 OS 키체인에 저장: python -m defi_agent.keys set wallet|hl-api

# ── 실행 모드 ──────────────────────────────────────────────
# true인 동안은 어떤 트랜잭션/주문도 전송하지 않고 로그만 남긴다.
DRY_RUN=true

# ── Base 체인 ──────────────────────────────────────────────
BASE_RPC=https://mainnet.base.org
# 프라이빗키는 .env에 저장하지 않는다 — Windows 자격 증명 관리자 사용:
#   python -m defi_agent.keys set wallet    (Base 운용 지갑)
#   python -m defi_agent.keys set hl-api    (Hyperliquid API wallet)
# .env의 WALLET_PRIVATE_KEY / HL_API_WALLET_KEY는 폴백일 뿐이며 경고가 뜬다.

# ── LP 설정 ────────────────────────────────────────────────
# Aerodrome Slipstream WETH/USDC. 풀은 factory에서 tickSpacing으로 런타임 해석.
LP_TICK_SPACING=100
# 레인지 반폭 (현재가 대비 ±%). 집중도 m = 1/(1-(lo/hi)^0.25) — IL이 m배로 커진다.
#   ±10% -> m=20.4 · ±20% -> m=10.4 · ±35% -> m=6.0 · ±50% -> m=4.2 · ±67% -> m=3.0
# 주의: 백테스트 §5.2의 "m<=3 ≈ ±35%"는 산술 오류였다 (실제 ±35%는 m=6.0).
# 현재 35는 측정 대기 중인 잠정값 — docs/DELTA_NEUTRAL_LP_BACKTEST.md §5.2 참고.
LP_RANGE_PCT=35
# 총 LP 투입 한도 (USDC, 하드캡 — 에이전트는 이 이상 절대 예치 불가)
LP_MAX_USDC=5000
# 가격이 레인지 경계의 이 비율 안에 들어오면 재배치 (0.9 = 경계까지 90% 도달 시)
RERANGE_TRIGGER=0.90
# 자동 재배치 최소 간격 (시간)
RERANGE_COOLDOWN_H=12

# ── Hyperliquid 헤지 ───────────────────────────────────────
# API 키는 키체인 사용 (위 참고). 계정 주소는 비밀 아님 → .env 가능
# (quant .env의 HL_ACCOUNT_ADDRESS 재사용됨)
HL_ACCOUNT_ADDRESS=
HL_COIN=ETH
# 델타 드리프트 허용치 (5% 초과 시 재헤지)
HEDGE_DRIFT_PCT=5
# 헤지 레버리지 상한 (백테스트 권고: 3x, 5x 이상 금지)
HL_MAX_LEVERAGE=3

# ── 텔레그램 (@mjquant_bot) ────────────────────────────────
TG_BOT_TOKEN=
# 알림 받을 chat_id (봇에게 /start 보낸 뒤 로그에서 확인 가능)
TG_CHAT_ID=

# ── 루프 주기 ──────────────────────────────────────────────
REBALANCE_INTERVAL_SEC=600
# 정기 상태 알림 간격(분). 0이면 비활성 — 액션·경보만 알림.
# 사이클에 얹어 발송하므로 실제 간격은 사이클 단위로 올림된다.
STATUS_NOTIFY_MIN=60
DAILY_REPORT_HOUR_KST=9
